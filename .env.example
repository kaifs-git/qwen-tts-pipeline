# Required for local + Phase C — Groq cloud STT (whisper) + LLM (llama-3.3-70b)
GROQ_API_KEY=your_groq_api_key_here

# Phase C only (vast.ai) — model repo is gated. NOTE: `Qwen/Qwen3-TTS` is a
# collection, not a repo. Real weights: Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice.
# Accept terms in browser first at:
# https://huggingface.co/Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice , then paste token.
HUGGINGFACE_HUB_TOKEN=hf_your_token_here

# Phase C only (vast.ai) — point HF cache at the big /workspace partition so
# the ~3.5 GB model download doesn't fill the small root partition.
# HF_HOME=/workspace/hf_cache
